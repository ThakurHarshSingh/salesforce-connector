# Salesforce → Auditify connector configuration.
# Copy to .env and fill in. Never commit the real .env or any private key.

# --- Salesforce: shared ---
# Consumer Key of your Connected App.
SF_CLIENT_ID=

# 'login' for production / developer orgs, 'test' for sandboxes.
SF_DOMAIN=login

# --- Salesforce: OAuth Authorization Code flow ("Connect Salesforce" button) ---
# Used by `sf-connector login`. This is the flow the product uses.
# Consumer Secret of your Connected App.
SF_CLIENT_SECRET=

# OAuth callback. Must match a Callback URL configured on the Connected App.
SF_REDIRECT_URI=http://localhost:1717/callback

# --- Salesforce: JWT Bearer flow (headless, single integration user) ---
# Only needed for the non-interactive `check`/`sync` path. Leave blank if you
# connect interactively with `sf-connector login`.
SF_USERNAME=
SF_PRIVATE_KEY_FILE=

# --- Auditify (the target product) ---
# Public base URL; nginx routes /api to the backend.
AUDITIFY_BASE_URL=http://localhost

# Auditify JWT access token. Must carry a tenant claim (call /auth/select-tenant
# after login to obtain a tenant-scoped token).
AUDITIFY_ACCESS_TOKEN=
